<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFrameworks>net10.0-windows10.0.26100.0;net481</TargetFrameworks>
    <ImplicitUsings>disable</ImplicitUsings>
    <Nullable>disable</Nullable>
    <Platforms>AnyCPU</Platforms>
    <PlatformTarget>AnyCPU</PlatformTarget>
    <LangVersion>latest</LangVersion>
  </PropertyGroup>
  <ItemGroup>
    <EmbeddedResource Include="..\Certificates\PsdzRpcClient.pfx" Link="Certificates\PsdzRpcClient.pfx" Condition="Exists('..\Certificates\PsdzRpcClient.pfx')" />
    <EmbeddedResource Include="..\Certificates\PsdzRpcCa.crt"     Link="Certificates\PsdzRpcCa.crt"     Condition="Exists('..\Certificates\PsdzRpcCa.crt')" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="CommandLineParser" Version="2.9.1" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\PsdzRpcClientLibrary\PsdzRpcClientLibrary.csproj" />
  </ItemGroup>
</Project>

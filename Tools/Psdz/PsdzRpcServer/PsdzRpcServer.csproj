<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFrameworks>net10.0-windows10.0.26100.0;net481</TargetFrameworks>
    <ImplicitUsings>disable</ImplicitUsings>
    <Nullable>disable</Nullable>
    <Platforms>AnyCPU</Platforms>
    <PlatformTarget>AnyCPU</PlatformTarget>
    <LangVersion>latest</LangVersion>
  </PropertyGroup>
  <ItemGroup>
    <Content Include="..\PsdzClient\log4net_config.xml" Link="log4net_config.xml">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>
  <ItemGroup>
    <EmbeddedResource Include="$(RpcCertificates)\PsdzRpcServer.pfx" Link="$(RpcCertificatesLink)\PsdzRpcServer.pfx" Condition="Exists('$(RpcCertificates)\PsdzRpcServer.pfx')" />
    <EmbeddedResource Include="$(RpcCertificates)\PsdzRpcCa.crt"     Link="$(RpcCertificatesLink)\PsdzRpcCa.crt"     Condition="Exists('$(RpcCertificates)\PsdzRpcCa.crt')" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="CommandLineParser" Version="2.9.1" />
    <PackageReference Include="Nerdbank.MessagePack" Version="1.1.62" />
    <PackageReference Include="StreamJsonRpc" Version="2.24.84" />
    <PackageReference Include="System.Security.Cryptography.Xml" Version="10.0.7" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\PsdzClientLibrary\PsdzClientLibrary.csproj" />
  </ItemGroup>
</Project>

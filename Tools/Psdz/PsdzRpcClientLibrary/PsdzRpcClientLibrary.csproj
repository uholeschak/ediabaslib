<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <_AndroidTargets Condition="'$(EnableAndroidTargets)' == 'true'">net10.0-android36.1</_AndroidTargets>
    <TargetFrameworks>net10.0-windows10.0.26100.0;net481;$(_AndroidTargets)</TargetFrameworks>
    <ImplicitUsings>disable</ImplicitUsings>
    <Nullable>disable</Nullable>
    <Platforms>AnyCPU</Platforms>
    <PlatformTarget>AnyCPU</PlatformTarget>
    <LangVersion>latest</LangVersion>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="..\PsdzRpcServer\Shared\**\*.cs" LinkBase="Shared" />
  </ItemGroup>
  <ItemGroup Condition="$(TargetFramework.Contains('android'))">
    <Compile Remove="PsdzRpcServerStarter.cs" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Nerdbank.MessagePack" Version="1.1.62" />
    <PackageReference Include="StreamJsonRpc" Version="2.24.84" />
  </ItemGroup>
  <ItemGroup Condition="!$(TargetFramework.Contains('android'))">
    <PackageReference Include="System.ServiceProcess.ServiceController" Version="10.0.8" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\..\EdiabasLib\EdiabasLib\EdiabasLib.csproj" />
  </ItemGroup>
</Project>

<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <_DotNetRoot Condition="'$(DOTNET_ROOT)' != ''">$(DOTNET_ROOT)</_DotNetRoot>
    <_DotNetRoot Condition="'$(_DotNetRoot)' == '' And Exists('C:\Program Files\dotnet')">C:\Program Files\dotnet</_DotNetRoot>
    <_DotNetRoot Condition="'$(_DotNetRoot)' == '' And Exists('$(LOCALAPPDATA)\Microsoft\dotnet')">$(LOCALAPPDATA)\Microsoft\dotnet</_DotNetRoot>
    <_DotNetRoot Condition="'$(_DotNetRoot)' == '' And Exists('$(VSINSTALLDIR)\dotnet')">$(VSINSTALLDIR)\dotnet</_DotNetRoot>
    <_AndroidWorkloadInstalled Condition="Exists('$(_DotNetRoot)\packs\Microsoft.Android.Sdk.Windows')">true</_AndroidWorkloadInstalled>
    <_AndroidTargets Condition="'$(_AndroidWorkloadInstalled)' == 'true'">net10.0-android36.1</_AndroidTargets>
    <TargetFrameworks>net10.0-windows10.0.26100.0;net481;$(_AndroidTargets)</TargetFrameworks>
    <ImplicitUsings>disable</ImplicitUsings>
    <Nullable>disable</Nullable>
    <Platforms>AnyCPU</Platforms>
    <PlatformTarget>AnyCPU</PlatformTarget>
    <LangVersion>latest</LangVersion>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="..\PsdzRpcServer\Shared\**\*.cs" LinkBase="Shared" />
  </ItemGroup>
  <ItemGroup Condition="$(TargetFramework.Contains('android'))">
    <Compile Remove="PsdzRpcServerStarter.cs" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Nerdbank.MessagePack" Version="1.1.62" />
    <PackageReference Include="StreamJsonRpc" Version="2.24.84" />
  </ItemGroup>
  <ItemGroup Condition="!$(TargetFramework.Contains('android'))">
    <PackageReference Include="System.ServiceProcess.ServiceController" Version="10.0.7" />
  </ItemGroup>
  <ItemGroup Condition="!$(TargetFramework.Contains('android'))">
    <ProjectReference Include="..\..\..\EdiabasLib\EdiabasLib\EdiabasLib.csproj" />
  </ItemGroup>
  <ItemGroup Condition="$(TargetFramework.Contains('android'))">
    <ProjectReference Include="..\..\..\EdiabasLib\EdiabasLibAndroidNet\EdiabasLibAndroidNet.csproj" />
  </ItemGroup>
</Project>
